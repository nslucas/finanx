API_BIND_ADDRESS=127.0.0.1
API_PORT=8080

MYSQL_DATABASE=prospera
MYSQL_USER=prospera
MYSQL_PASSWORD=change-this-database-password
MYSQL_ROOT_PASSWORD=change-this-root-password

JWT_SECRET=change-this-long-random-secret
JWT_EXPIRATION_HOURS=720
CORS_ALLOWED_ORIGIN_PATTERNS=https://appprospera.com.br,https://www.appprospera.com.br,https://api.appprospera.com.br

PUSH_VAPID_PUBLIC_KEY=change-this-vapid-public-key
PUSH_VAPID_PRIVATE_KEY=change-this-vapid-private-key
PUSH_VAPID_SUBJECT=mailto:admin@appprospera.com.br
NOTIFICATIONS_DIGEST_CRON=0 0 9 * * *
NOTIFICATIONS_CLEANUP_CRON=0 30 3 * * SUN
NOTIFICATIONS_RETENTION_DAYS=90
